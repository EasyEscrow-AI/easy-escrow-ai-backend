# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/easyescrow_db?schema=public"

# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Escrow Program
ESCROW_PROGRAM_ID=

# Keypairs and Secrets (mounted from App Platform secrets)
FEE_COLLECTOR_PRIVATE_KEY=
ADMIN_PRIVATE_KEY=

# Security
JWT_SECRET=
API_KEY_SECRET=

# Redis Configuration (for caching and queues)
REDIS_URL=

# USDC Token Configuration
USDC_MINT_ADDRESS=

# Platform Configuration
PLATFORM_FEE_BPS=250
ALLOWED_DOMAINS=easyescrow.ai,*.easyescrow.ai

# Webhook Configuration
WEBHOOK_SECRET=
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_DELAY_MS=1000

# cNFT / DAS API Configuration
# Settings for handling stale Merkle proofs on high-activity trees
# If swap works, it should work 1st try. 2nd try catches indexer lag. 3rd is last resort.

# Maximum retry attempts when DAS returns stale proofs (default: 3)
CNFT_STALE_PROOF_MAX_RETRIES=3

# Maximum retry attempts when DAS returns stale ownership data (default: 3)
# Stale ownership data can occur after recent cNFT transfers before DAS indexes the change
CNFT_STALE_OWNERSHIP_MAX_RETRIES=3

# Tree sequence stability check settings
# Max checks before giving up on stability (default: 3)
CNFT_STABILITY_MAX_CHECKS=3
# Interval between stability checks in ms (default: 1000)
CNFT_STABILITY_CHECK_INTERVAL=1000
# Required consecutive stable checks (default: 2)
CNFT_STABILITY_REQUIRED_CHECKS=2

# DAS API rate limiting
# Interval between DAS requests in ms (default: 750, ~1.33 rps)
# Increase if hitting 429 errors from QuickNode (free tier is 2 rps)
DAS_RATE_LIMIT_INTERVAL_MS=750

# JITO Configuration
# Enable/disable JITO bundles for atomic multi-transaction execution
# - 'true': Use JITO bundles for atomic cNFT swaps (recommended for mainnet)
# - 'false': Use sequential RPC with JIT proof validation (safer for high-activity trees)
# When disabled, each cNFT transaction validates its Merkle proof before submission
# and rebuilds with fresh proof if stale. This prevents "error 6001" stale proof failures.
ENABLE_JITO_BUNDLES=false

# JITO tip amount in lamports (1 SOL = 1,000,000,000 lamports)
# Higher tips increase priority during network congestion
# Default: 1,000,000 (0.001 SOL) - reasonable for normal conditions
# During high congestion, consider 2,000,000-5,000,000 (0.002-0.005 SOL)
JITO_TIP_LAMPORTS=1000000

# ============================================================================
# Institution Escrow Configuration
# Only required when INSTITUTION_ESCROW_ENABLED=true
# ============================================================================

# Institution Escrow
INSTITUTION_ESCROW_ENABLED=false
USDC_MINT_ADDRESS=

# Institution Escrow Limits
INSTITUTION_ESCROW_MIN_USDC=100
INSTITUTION_ESCROW_MAX_USDC=1000000
INSTITUTION_ESCROW_DEFAULT_EXPIRY_HOURS=72

# Auth (JWT)
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# AI Analysis
ANTHROPIC_API_KEY=
AI_ANALYSIS_MODEL=claude-sonnet-4-20250514

# DO Spaces (already have @aws-sdk/client-s3 in deps)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=
DO_SPACES_BUCKET=
DO_SPACES_REGION=

# Settlement
SETTLEMENT_AUTHORITY_API_KEY=
