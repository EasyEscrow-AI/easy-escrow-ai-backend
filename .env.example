# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/easyescrow_db?schema=public"

# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Escrow Program
ESCROW_PROGRAM_ID=

# Keypairs and Secrets (mounted from App Platform secrets)
FEE_COLLECTOR_PRIVATE_KEY=
ADMIN_PRIVATE_KEY=

# Security
JWT_SECRET=
API_KEY_SECRET=

# Redis Configuration (for caching and queues)
REDIS_URL=

# USDC Token Configuration
USDC_MINT_ADDRESS=

# Platform Configuration
PLATFORM_FEE_BPS=250
ALLOWED_DOMAINS=easyescrow.ai,*.easyescrow.ai

# Webhook Configuration
WEBHOOK_SECRET=
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_DELAY_MS=1000
