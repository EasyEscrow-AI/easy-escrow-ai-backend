{
  "name": "easy-escrow-ai-backend",
  "version": "1.0.0",
  "description": "Backend service for EasyEscrow.ai - an AI-powered escrow platform for Solana NFT and USDC transactions.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:program": "cd programs/easyescrow && anchor build",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:program": "cd programs/easyescrow && npm test",
    "test:program:unit": "cd programs/easyescrow && npm run test:unit",
    "test:program:integration": "cd programs/easyescrow && npm run test:integration",
    "deploy:program": "cd programs/easyescrow && npm run deploy"
  },
  "keywords": [
    "escrow",
    "solana",
    "nft",
    "usdc",
    "blockchain",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0"
  }
}
