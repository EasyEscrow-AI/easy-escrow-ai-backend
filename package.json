{
  "name": "easy-escrow-ai-backend",
  "version": "1.0.0",
  "description": "Backend API service for EasyEscrow.ai - Escrow platform with Solana integration",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc && npm run postbuild",
    "postbuild": "node -e \"require('fs').cpSync('src/generated', 'dist/generated', {recursive: true})\"",
    "start": "node dist/index.js",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "db:seed:staging": "ts-node prisma/seed-staging.ts",
    "db:test-connection": "ts-node scripts/utilities/test-db-connection.ts",
    "db:reset": "prisma migrate reset",
    "db:setup": "npm run db:generate && npm run db:migrate",
    "test": "mocha --require ts-node/register 'tests/**/*.test.ts' --timeout 30000",
    "test:unit": "mocha --require ts-node/register 'tests/unit/**/*.test.ts' --timeout 10000",
    "test:integration": "mocha --require ts-node/register 'tests/integration/**/*.test.ts' --timeout 20000",
    "test:on-chain": "anchor test --skip-local-validator",
    "test:on-chain:comprehensive": "mocha --require ts-node/register 'tests/on-chain/**/*.test.ts' --timeout 60000",
    "test:e2e": "mocha --no-config --require ts-node/register tests/e2e/devnet-nft-usdc-swap.test.ts --timeout 180000 --reporter spec --colors --inline-diffs",
    "test:e2e:verbose": "mocha --no-config --require ts-node/register tests/e2e/devnet-nft-usdc-swap.test.ts --timeout 180000 --reporter spec --colors --inline-diffs --full-trace",
    "test:localnet": "mocha --require ts-node/register 'tests/localnet/**/*.test.ts' --timeout 60000",
    "test:localnet:comprehensive": "mocha --require ts-node/register 'tests/localnet/localnet-comprehensive.test.ts' --timeout 60000",
    "test:coverage": "echo 'Coverage reporting not yet configured'",
    "test:watch": "mocha --require ts-node/register 'tests/**/*.test.ts' --watch --watch-files 'src/**/*.ts,tests/**/*.ts'",
    "test:ci": "npm run test:unit && npm run test:integration",
    "localnet:start": "powershell -ExecutionPolicy Bypass -File ./scripts/development/localnet/start-localnet-validator.ps1",
    "localnet:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/development/localnet/setup-localnet.ps1",
    "localnet:setup-nfts": "powershell -ExecutionPolicy Bypass -File ./scripts/development/localnet/setup-nft-collection.ps1",
    "localnet:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/development/localnet/reset-localnet.ps1",
    "timeout:help": "ts-node scripts/utilities/timeout/run-with-timeout.ts --help",
    "timeout:help:ps": "powershell -ExecutionPolicy Bypass -File ./scripts/utilities/timeout/run-with-timeout.ps1 -Help",
    "verify:rpc": "ts-node scripts/testing/verify-rpc-config.ts",
    "idl:copy-dev": "powershell -ExecutionPolicy Bypass -File ./scripts/utilities/copy-idl-for-env.ps1 -Environment dev -ProgramId 4FQ5JoxsS5jjuTR1ScuEpk66eX5B71L7ysJEysmsTwhd",
    "idl:copy-staging": "powershell -ExecutionPolicy Bypass -File ./scripts/utilities/copy-idl-for-env.ps1 -Environment staging -ProgramId AvdX6LEkoAmP961QwNjAUNpiuDtiQjaiSw5wR5zb9Zei",
    "idl:copy-all": "powershell -ExecutionPolicy Bypass -File ./scripts/utilities/build-all-idls.ps1",
    "idl:sync": "powershell -ExecutionPolicy Bypass -File ./scripts/utilities/copy-env-idls.ps1",
    "docker:start": "docker compose up -d",
    "docker:stop": "docker compose down",
    "docker:restart": "docker compose restart",
    "docker:restart:backend": "docker compose restart backend",
    "docker:restart:db": "docker compose restart postgres",
    "docker:restart:redis": "docker compose restart redis",
    "docker:rebuild": "docker compose up -d --build",
    "docker:rebuild:backend": "docker compose up -d --build backend",
    "docker:logs": "docker compose logs -f",
    "docker:logs:backend": "docker compose logs -f backend",
    "docker:logs:db": "docker compose logs -f postgres",
    "docker:logs:redis": "docker compose logs -f redis",
    "docker:ps": "docker compose ps",
    "docker:health": "docker compose ps && docker compose exec backend node -e \"require('http').get('http://localhost:3000/health', (r) => {let d='';r.on('data',c=>d+=c);r.on('end',()=>{console.log(d);process.exit(r.statusCode===200?0:1)})}).on('error',()=>process.exit(1))\" || echo 'Backend health check failed'",
    "docker:fresh": "powershell -ExecutionPolicy Bypass -File ./scripts/development/docker/docker-fresh-start.ps1",
    "docker:fresh:keep-data": "powershell -ExecutionPolicy Bypass -File ./scripts/development/docker/docker-fresh-start.ps1 -KeepData",
    "docker:fresh:seed": "powershell -ExecutionPolicy Bypass -File ./scripts/development/docker/docker-fresh-start.ps1 -Seed",
    "docker:clean": "docker compose down -v --rmi all && docker builder prune -f",
    "staging:setup-env": "powershell -ExecutionPolicy Bypass -File ./scripts/deployment/setup-staging-env.ps1",
    "staging:rotate-secrets": "powershell -ExecutionPolicy Bypass -File ./scripts/deployment/rotate-staging-secrets.ps1",
    "staging:build": "powershell -ExecutionPolicy Bypass -File ./scripts/deployment/staging/build-with-checksums.ps1",
    "staging:build:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/deployment/staging/build-with-checksums.ps1 -Clean",
    "staging:deploy": "powershell -ExecutionPolicy Bypass -File ./scripts/deployment/staging/deploy-to-staging.ps1",
    "staging:migrate": "powershell -ExecutionPolicy Bypass -File ./scripts/deployment/staging/post-deploy-migrate.ps1",
    "staging:fund-wallets": "powershell -ExecutionPolicy Bypass -File ./scripts/deployment/staging/fund-staging-wallets.ps1",
    "test:staging:smoke": "mocha --require ts-node/register tests/staging/staging-smoke.test.ts --timeout 60000 --reporter spec --colors",
    "test:staging:smoke:ci": "ts-node scripts/testing/smoke-tests.ts",
    "test:staging:e2e": "mocha --require ts-node/register --no-config tests/e2e/staging/staging-comprehensive-e2e.test.ts --timeout 300000 --reporter spec --colors",
    "test:staging:e2e:verbose": "mocha --require ts-node/register --no-config tests/e2e/staging/staging-comprehensive-e2e.test.ts --timeout 300000 --reporter spec --colors --full-trace",
    "test:cleanup": "ts-node scripts/utilities/cleanup-test-agreements.ts",
    "test:cleanup:all": "ts-node scripts/utilities/cleanup-test-agreements.ts --all-test",
    "test:cleanup:dry-run": "ts-node scripts/utilities/cleanup-test-agreements.ts --all-test --dry-run",
    "program:switch:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/utilities/switch-program-environment.ps1 -Environment dev",
    "program:switch:staging": "powershell -ExecutionPolicy Bypass -File ./scripts/utilities/switch-program-environment.ps1 -Environment staging",
    "program:build:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/utilities/switch-program-environment.ps1 -Environment dev -Build",
    "program:build:staging": "powershell -ExecutionPolicy Bypass -File ./scripts/utilities/switch-program-environment.ps1 -Environment staging -Build",
    "program:deploy:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/utilities/switch-program-environment.ps1 -Environment dev -Build -Deploy",
    "program:deploy:staging": "powershell -ExecutionPolicy Bypass -File ./scripts/utilities/switch-program-environment.ps1 -Environment staging -Build -Deploy",
    "staging:migrate:ci": "ts-node scripts/deployment/migrate-staging.ts",
    "staging:verify": "powershell -ExecutionPolicy Bypass -File ./scripts/deployment/verify-staging-deployment.ps1",
    "staging:verify:verbose": "powershell -ExecutionPolicy Bypass -File ./scripts/deployment/verify-staging-deployment.ps1 -Verbose",
    "staging:verify:skip-tests": "powershell -ExecutionPolicy Bypass -File ./scripts/deployment/verify-staging-deployment.ps1 -SkipSmokeTests",
    "staging:prepare-yaml": "powershell -ExecutionPolicy Bypass -File ./scripts/deployment/staging/prepare-app-yaml.ps1",
    "staging:prepare-yaml:dry-run": "powershell -ExecutionPolicy Bypass -File ./scripts/deployment/staging/prepare-app-yaml.ps1 -DryRun",
    "prepare": "husky"
  },
  "keywords": [
    "escrow",
    "solana",
    "api",
    "backend",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@metaplex-foundation/js": "^0.20.1",
    "@prisma/client": "^6.17.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@types/bs58": "^4.0.4",
    "@types/bull": "^3.15.9",
    "@types/ioredis": "^4.28.10",
    "bs58": "^6.0.0",
    "bull": "^4.16.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.1",
    "prisma": "^6.17.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/mocha": "^9.0.0",
    "@types/node": "^24.7.2",
    "@types/pg": "^8.15.5",
    "@types/sinon": "^17.0.4",
    "@types/supertest": "^6.0.3",
    "axios": "^1.12.2",
    "chai": "^4.3.4",
    "husky": "^9.1.7",
    "mocha": "^9.0.3",
    "nodemon": "^3.1.7",
    "pg": "^8.16.3",
    "prettier": "^2.6.2",
    "sinon": "^21.0.0",
    "supertest": "^7.1.4",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "ts-sinon": "^2.0.2",
    "typescript": "^5.9.3"
  }
}
