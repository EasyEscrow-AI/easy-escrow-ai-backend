{
  "name": "easy-escrow-ai-backend",
  "version": "1.0.0",
  "description": "Backend API service for EasyEscrow.ai - Escrow platform with Solana integration",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc && npm run postbuild",
    "postbuild": "node -e \"require('fs').cpSync('src/generated', 'dist/generated', {recursive: true})\"",
    "start": "node dist/index.js",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "db:seed:staging": "ts-node prisma/seed-staging.ts",
    "db:test-connection": "ts-node scripts/utilities/test-db-connection.ts",
    "db:reset": "prisma migrate reset",
    "db:setup": "npm run db:generate && npm run db:migrate",
    "test": "mocha --require ts-node/register 'tests/**/*.test.ts' --timeout 30000",
    "test:unit": "cross-env NODE_ENV=test mocha --require ts-node/register --no-config 'tests/unit/**/*.test.ts' --timeout 10000",
    "test:unit:receipt": "cross-env NODE_ENV=test mocha --require ts-node/register --no-config tests/unit/receipt.service.test.ts --timeout 10000 --reporter spec --colors",
    "test:unit:nft-deposit": "cross-env NODE_ENV=test mocha --require ts-node/register --no-config tests/unit/nft-deposit.service.test.ts --timeout 10000 --reporter spec --colors",
    "test:unit:usdc-deposit": "cross-env NODE_ENV=test mocha --require ts-node/register --no-config tests/unit/usdc-deposit.service.test.ts --timeout 10000 --reporter spec --colors",
    "test:unit:transaction-log": "cross-env NODE_ENV=test mocha --require ts-node/register --no-config tests/unit/transaction-log.service.test.ts --timeout 10000 --reporter spec --colors",
    "test:unit:refund": "cross-env NODE_ENV=test mocha --require ts-node/register --no-config tests/unit/refund.service.test.ts --timeout 10000 --reporter spec --colors",
    "test:unit:settlement-refund": "cross-env NODE_ENV=test mocha --require ts-node/register --no-config tests/unit/settlement-automatic-refund.test.ts --timeout 10000 --reporter spec --colors",
    "test:unit:token-accounts": "cross-env NODE_ENV=test mocha --require ts-node/register --no-config tests/unit/escrow-program-token-accounts.test.ts --timeout 10000 --reporter spec --colors",
    "test:unit:jito": "cross-env NODE_ENV=test mocha --require ts-node/register --no-config tests/unit/jito-integration.test.ts --timeout 10000 --reporter spec --colors",
    "test:unit:core-services": "cross-env NODE_ENV=test mocha --require ts-node/register --no-config 'tests/unit/{nft-deposit,usdc-deposit,transaction-log,refund,receipt}.service.test.ts' --timeout 10000 --reporter spec --colors",
    "test:integration": "mocha --require ts-node/register 'tests/integration/**/*.test.ts' --timeout 20000",
    "test:local:e2e": "mocha --require ts-node/register 'tests/local/e2e/**/*.test.ts' --timeout 60000",
    "test:local:e2e:comprehensive": "mocha --require ts-node/register tests/local/e2e/escrow-comprehensive.test.ts --timeout 60000",
    "test:development:e2e": "mocha --no-config --require ts-node/register tests/development/e2e/devnet-nft-usdc-swap.test.ts --timeout 180000 --reporter spec --colors --inline-diffs",
    "test:development:e2e:verbose": "mocha --no-config --require ts-node/register tests/development/e2e/devnet-nft-usdc-swap.test.ts --timeout 180000 --reporter spec --colors --inline-diffs --full-trace",
    "test:coverage": "echo 'Coverage reporting not yet configured'",
    "test:watch": "mocha --require ts-node/register 'tests/**/*.test.ts' --watch --watch-files 'src/**/*.ts,tests/**/*.ts'",
    "test:ci": "npm run test:unit && npm run test:integration",
