{
  "name": "easyescrow-ai-backend",
  "version": "1.0.0",
  "description": "Backend service for EasyEscrow.ai - an AI-powered escrow platform for Solana NFTs and USDC",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:clean": "rm -rf dist && npm run dev",
    "build": "tsc",
    "start": "node dist/index.js",
    "restart": "pkill -f 'ts-node-dev' && npm run dev",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint && npm run test",
    "validate:project": "ts-node scripts/validate-project.ts",
    "task:run": "node -r ts-node/register ./scripts/run-task.ts",
    "task:list": "node -r ts-node/register ./scripts/list-tasks.ts",
    "data:validate": "node -r ts-node/register ./scripts/validate-data.ts",
    "debug:clean": "rm -rf ./debug/* && touch ./debug/.gitkeep"
  },
  "keywords": [
    "solana",
    "nft",
    "escrow",
    "atomic-swap",
    "usdc",
    "blockchain"
  ],
  "author": "EasyEscrow.ai",
  "license": "UNLICENSED",
  "dependencies": {
    "@solana/web3.js": "^1.87.6",
    "@solana/spl-token": "^0.3.9",
    "@metaplex-foundation/mpl-token-metadata": "^3.2.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "axios": "^1.6.2",
    "crypto": "^1.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@types/jest": "^29.5.8",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}