# STAGING Environment Configuration Template
# Copy this file to .env.staging and fill in the actual values
# Last Updated: 2025-01-20

NODE_ENV=staging
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# STAGING Program ID (generated with solana-keygen)
DEVNET_STAGING_PROGRAM_ID=your_staging_program_id_here

# STAGING Wallets (Base58 Private Keys - same format as DEV)
# Sender Wallet
# Address: your_sender_wallet_address_here
DEVNET_STAGING_SENDER_PRIVATE_KEY=your_staging_sender_base58_key_here

# Receiver Wallet
# Address: your_receiver_wallet_address_here
DEVNET_STAGING_RECEIVER_PRIVATE_KEY=your_staging_receiver_base58_key_here

# Admin Wallet
# Address: your_admin_wallet_address_here
DEVNET_STAGING_ADMIN_PRIVATE_KEY=your_staging_admin_base58_key_here

# Fee Collector Wallet
# Address: your_fee_collector_wallet_address_here
DEVNET_STAGING_FEE_COLLECTOR_ADDRESS=your_staging_fee_collector_address_here
DEVNET_STAGING_FEE_COLLECTOR_PRIVATE_KEY=your_staging_fee_collector_base58_key_here

# Official USDC Devnet Mint
DEVNET_STAGING_USDC_MINT_ADDRESS=Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr

# Redis (STAGING)
REDIS_URL=your_staging_redis_url_here

# Database (to be configured in Task 67)
# DATABASE_URL=your_staging_database_url_here

# Platform Configuration
PLATFORM_FEE_BPS=100
LOG_LEVEL=debug

# Monitoring
MONITORING_ENDPOINT=https://staging-api.easyescrow.ai/health
