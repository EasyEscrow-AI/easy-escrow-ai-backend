// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum for agreement status
enum AgreementStatus {
  PENDING
  FUNDED
  SOL_LOCKED  // Buyer's SOL deposited, waiting for NFT(s)
  NFT_LOCKED  // NFT deposited, waiting for SOL
  BOTH_LOCKED // All deposits complete, ready for settlement
  SETTLED
  EXPIRED
  CANCELLED
  REFUNDED
  ARCHIVED
}

// Enum for swap type (SOL migration)
enum SwapType {
  NFT_FOR_SOL // NFT <> SOL: Direct exchange
  NFT_FOR_NFT_WITH_FEE // NFT <> NFT: Buyer pays separate SOL fee
  NFT_FOR_NFT_PLUS_SOL // NFT <> NFT+SOL: Fee extracted from SOL amount
}

// Enum for fee payer (SOL migration)
enum FeePayer {
  BUYER // Default: Buyer pays the platform fee
  SELLER // Alternative: Seller pays the platform fee
}

// Enum for deposit type
enum DepositType {
  NFT // NFT deposits (seller's NFT A or buyer's NFT B)
  SOL // SOL deposits from buyer
  NFT_BUYER // Buyer's NFT deposit (for NFT<>NFT swaps)
}

// Enum for deposit status
enum DepositStatus {
  PENDING
  CONFIRMED
  FAILED
}

// Enum for webhook event type
enum WebhookEventType {
  ESCROW_FUNDED
  ESCROW_ASSET_LOCKED
  ESCROW_SETTLED
  ESCROW_EXPIRED
  ESCROW_REFUNDED
}

// Enum for webhook delivery status
enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

// Main Agreements table
model Agreement {
  id              String          @id @default(uuid())
  agreementId     String          @unique @map("agreement_id")
  escrowPda       String          @map("escrow_pda")
  nftMint         String          @map("nft_mint")
  seller          String
  buyer           String?
  price           Decimal         @db.Decimal(20, 9)
  feeBps          Int             @map("fee_bps")
  honorRoyalties  Boolean         @default(false) @map("honor_royalties")
  status          AgreementStatus @default(PENDING)
  expiry          DateTime
  nftDepositAddr  String?         @map("nft_deposit_addr")  // Seller's NFT (NFT A) deposit address
  nftBDepositAddr String?         @map("nft_b_deposit_addr") // Buyer's NFT (NFT B) deposit address (for NFT<>NFT swaps)
  initTxId        String?         @map("init_tx_id")
  settleTxId      String?         @map("settle_tx_id")
  cancelTxId      String?         @map("cancel_tx_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  settledAt       DateTime?       @map("settled_at")
  cancelledAt     DateTime?       @map("cancelled_at")
  archivedAt      DateTime?       @map("archived_at")
  archiveReason   String?         @map("archive_reason")

  // SOL Migration fields
  swapType  SwapType? @map("swap_type") // Type of swap (NFT<>SOL, NFT<>NFT, etc.)
  solAmount Decimal?  @map("sol_amount") @db.Decimal(20, 9) // SOL amount (lamports stored as decimal)
  nftBMint  String?   @map("nft_b_mint") // Buyer's NFT mint (for NFT<>NFT swaps)
  feePayer  FeePayer? @default(BUYER) @map("fee_payer") // Who pays the platform fee

  deposits   Deposit[]
  settlement Settlement?
  receipt    Receipt?
  webhooks   Webhook[]

  @@index([agreementId])
  @@index([seller])
  @@index([buyer])
  @@index([status])
  @@index([expiry])
  @@index([createdAt])
  @@index([archivedAt])
  @@index([nftBMint]) // Index for NFT B lookups
  @@index([swapType]) // Index for filtering by swap type
  // Composite indexes for scalability and batch processing
  @@index([status, expiry], name: "idx_status_expiry")
  @@index([expiry, seller, buyer], name: "idx_expiry_seller_buyer")
  @@map("agreements")
}

// Deposits table
model Deposit {
  id           String        @id @default(uuid())
  agreementId  String        @map("agreement_id")
  type         DepositType
  depositor    String
  amount       Decimal?      @db.Decimal(20, 9)
  tokenAccount String?       @map("token_account")
  status       DepositStatus @default(PENDING)
  txId         String?       @map("tx_id")
  blockHeight  BigInt?       @map("block_height")
  nftMetadata  Json?         @map("nft_metadata")
  detectedAt   DateTime      @default(now()) @map("detected_at")
  confirmedAt  DateTime?     @map("confirmed_at")

  agreement Agreement @relation(fields: [agreementId], references: [agreementId], onDelete: Cascade)

  @@index([agreementId])
  @@index([type])
  @@index([status])
  @@index([depositor])
  @@index([detectedAt])
  @@map("deposits")
}

// Idempotency keys table - prevents duplicate operations
model IdempotencyKey {
  id             String   @id @default(uuid())
  key            String   @unique
  endpoint       String
  requestHash    String   @map("request_hash")
  responseStatus Int      @map("response_status")
  responseBody   Json     @map("response_body")
  createdAt      DateTime @default(now()) @map("created_at")
  expiresAt      DateTime @map("expires_at")

  @@index([key])
  @@index([endpoint])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// Settlements table
model Settlement {
  id               String   @id @default(uuid())
  agreementId      String   @unique @map("agreement_id")
  nftMint          String   @map("nft_mint")
  price            Decimal  @db.Decimal(20, 9)
  platformFee      Decimal  @map("platform_fee") @db.Decimal(20, 9)
  creatorRoyalty   Decimal? @map("creator_royalty") @db.Decimal(20, 9)
  sellerReceived   Decimal  @map("seller_received") @db.Decimal(20, 9)
  settleTxId       String   @map("settle_tx_id")
  blockHeight      BigInt   @map("block_height")
  buyer            String
  seller           String
  feeCollector     String?  @map("fee_collector")
  royaltyRecipient String?  @map("royalty_recipient")
  settledAt        DateTime @default(now()) @map("settled_at")

  agreement Agreement @relation(fields: [agreementId], references: [agreementId], onDelete: Cascade)

  @@index([agreementId])
  @@index([buyer])
  @@index([seller])
  @@index([nftMint])
  @@index([settledAt])
  @@map("settlements")
}

// Receipts table
model Receipt {
  id             String   @id @default(uuid())
  agreementId    String   @unique @map("agreement_id")
  nftMint        String   @map("nft_mint")
  price          Decimal  @db.Decimal(20, 9)
  platformFee    Decimal  @map("platform_fee") @db.Decimal(20, 9)
  creatorRoyalty Decimal? @map("creator_royalty") @db.Decimal(20, 9)
  buyer          String
  seller         String

  // All transaction IDs for complete audit trail
  escrowTxId      String  @map("escrow_tx_id") // Init/creation transaction
  depositNftTxId  String? @map("deposit_nft_tx_id") // NFT deposit transaction
  depositUsdcTxId String? @map("deposit_usdc_tx_id") // USDC deposit transaction
  settlementTxId  String  @map("settlement_tx_id") // Final settlement transaction

  receiptHash String   @unique @map("receipt_hash")
  signature   String
  createdAt   DateTime @map("created_at")
  settledAt   DateTime @map("settled_at")
  generatedAt DateTime @default(now()) @map("generated_at")

  agreement Agreement @relation(fields: [agreementId], references: [agreementId], onDelete: Cascade)

  @@index([agreementId])
  @@index([buyer])
  @@index([seller])
  @@index([nftMint])
  @@index([receiptHash])
  @@index([generatedAt])
  @@map("receipts")
}

// Transaction logs table
model TransactionLog {
  id            String   @id @default(uuid())
  agreementId   String?  @map("agreement_id")
  txId          String   @unique @map("tx_id")
  operationType String   @map("operation_type")
  blockHeight   BigInt?  @map("block_height")
  slot          BigInt?
  status        String
  errorMessage  String?  @map("error_message")
  timestamp     DateTime @default(now())

  @@index([agreementId])
  @@index([txId])
  @@index([operationType])
  @@index([status])
  @@index([timestamp])
  @@map("transaction_logs")
}

// Webhooks table
model Webhook {
  id               String                @id @default(uuid())
  agreementId      String                @map("agreement_id")
  eventType        WebhookEventType      @map("event_type")
  targetUrl        String                @map("target_url")
  payload          Json
  status           WebhookDeliveryStatus @default(PENDING)
  attempts         Int                   @default(0)
  maxAttempts      Int                   @default(5) @map("max_attempts")
  lastAttemptAt    DateTime?             @map("last_attempt_at")
  lastResponseCode Int?                  @map("last_response_code")
  lastResponseBody String?               @map("last_response_body")
  deliveredAt      DateTime?             @map("delivered_at")
  signature        String?
  createdAt        DateTime              @default(now()) @map("created_at")
  scheduledFor     DateTime              @default(now()) @map("scheduled_for")

  agreement Agreement @relation(fields: [agreementId], references: [agreementId], onDelete: Cascade)

  @@index([agreementId])
  @@index([eventType])
  @@index([status])
  @@index([scheduledFor])
  @@index([createdAt])
  @@map("webhooks")
}

// ============================================
// ATOMIC SWAP SYSTEM TABLES
// ============================================

// Enum for nonce pool status
enum NonceStatus {
  AVAILABLE
  IN_USE
  EXPIRED
  INVALID
}

// Enum for offer type
enum OfferType {
  MAKER_OFFER
  COUNTER_OFFER
  COUNTER // Alias for counter-offers
}

// Enum for offer status
enum OfferStatus {
  ACTIVE    // Offer is open and can be accepted
  ACCEPTED  // Offer has been accepted, transaction built and ready for signing
  FILLED    // Swap has been executed successfully
  CANCELLED // Offer was cancelled by maker
  EXPIRED   // Offer expired based on expires_at timestamp
  COUNTERED // Original offer received a counter-offer
  REJECTED  // Offer was rejected by the target (owner of requested assets)
}

// Enum for swap transaction status
enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
  CANCELLED
}

// Users table for atomic swap system
model User {
  id                      String   @id @default(uuid())
  walletAddress           String   @unique @map("wallet_address")
  nonceAccount            String?  @map("nonce_account")
  isSubsidized            Boolean  @default(false) @map("is_subsidized")
  totalSwapsCompleted     Int      @default(0) @map("total_swaps_completed")
  totalFeesPaidLamports   BigInt   @default(0) @map("total_fees_paid_lamports")
  swapStats               Json     @default("{}") @map("swap_stats")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  // Relations
  makerOffers       SwapOffer[]       @relation("MakerOffers")
  makerTransactions SwapTransaction[] @relation("MakerTransactions")
  takerTransactions SwapTransaction[] @relation("TakerTransactions")

  @@index([walletAddress])
  @@index([nonceAccount])
  @@map("users")
}

// Nonce pool table for durable nonce accounts
model NoncePool {
  id           Int         @id @default(autoincrement())
  nonceAccount String      @unique @map("nonce_account")
  status       NonceStatus @default(AVAILABLE)
  lastUsedAt   DateTime?   @map("last_used_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  // Relations
  offers SwapOffer[]

  @@index([status])
  @@index([lastUsedAt])
  @@map("nonce_pool")
}

// Swap offers table
model SwapOffer {
  id                     Int         @id @default(autoincrement())
  makerWallet            String      @map("maker_wallet")
  takerWallet            String?     @map("taker_wallet")
  offerType              OfferType   @map("offer_type")
  parentOfferId          Int?        @map("parent_offer_id")
  offeredAssets          Json        @map("offered_assets")
  requestedAssets        Json        @map("requested_assets")
  offeredSolLamports     BigInt?     @map("offered_sol_lamports")
  requestedSolLamports   BigInt?     @map("requested_sol_lamports")
  platformFeeLamports    BigInt      @map("platform_fee_lamports")
  status                 OfferStatus @default(ACTIVE)
  expiresAt              DateTime    @map("expires_at")
  nonceAccount           String      @map("nonce_account")
  currentNonceValue      String?     @map("current_nonce_value")
  serializedTransaction  String?     @map("serialized_transaction") @db.Text
  transactionSignature   String?     @map("transaction_signature")
  filledAt               DateTime?   @map("filled_at")
  cancelledAt            DateTime?   @map("cancelled_at")
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")

  // Bulk swap fields (for 3+ cNFT swaps using Jito bundles)
  isBulkSwap             Boolean     @default(false) @map("is_bulk_swap")
  bundleId               String?     @map("bundle_id") // Jito bundle ID for multi-transaction swaps
  transactionCount       Int         @default(1) @map("transaction_count") // Number of transactions in bundle
  bundleStatus           String?     @map("bundle_status") // Pending, Landed, Failed, Timeout

  // Enhanced offer management fields
  cancelledBy            String?     @map("cancelled_by") // Wallet address that cancelled the offer
  rejectedAt             DateTime?   @map("rejected_at") // When the offer was rejected
  rejectedBy             String?     @map("rejected_by") // Wallet address that rejected the offer
  updateCount            Int         @default(0) @map("update_count") // Number of times offer was modified

  // Relations
  maker               User              @relation("MakerOffers", fields: [makerWallet], references: [walletAddress], onDelete: Cascade)
  nonce               NoncePool         @relation(fields: [nonceAccount], references: [nonceAccount])
  parentOffer         SwapOffer?        @relation("CounterOffers", fields: [parentOfferId], references: [id])
  counterOffers       SwapOffer[]       @relation("CounterOffers")
  transactions        SwapTransaction[] @relation("OfferTransactions")
  counterTransactions SwapTransaction[] @relation("CounterOfferTransactions")
  twoPhaseSwap        TwoPhaseSwap?     @relation("TwoPhaseSwapOffer")

  @@index([makerWallet])
  @@index([takerWallet])
  @@index([status])
  @@index([expiresAt])
  @@index([parentOfferId])
  @@index([nonceAccount])
  @@index([status, expiresAt], name: "idx_offer_status_expiry")
  @@index([bundleId])
  @@index([isBulkSwap])
  @@map("swap_offers")
}

// Swap transactions table
model SwapTransaction {
  id                             Int               @id @default(autoincrement())
  offerId                        Int               @map("offer_id")
  counterOfferId                 Int?              @map("counter_offer_id")
  signature                      String            @unique
  makerWallet                    String            @map("maker_wallet")
  takerWallet                    String            @map("taker_wallet")
  platformFeeCollectedLamports   BigInt            @map("platform_fee_collected_lamports")
  totalValueLamports             BigInt            @map("total_value_lamports")
  executedAt                     DateTime          @map("executed_at")
  transactionSignature           String?           @map("transaction_signature")
  status                         TransactionStatus @default(PENDING)
  gasFee                         BigInt?           @map("gas_fee")
  isSubsidized                   Boolean           @default(false) @map("is_subsidized")
  errorMessage                   String?           @map("error_message")
  confirmedAt                    DateTime?         @map("confirmed_at")
  createdAt                      DateTime          @default(now()) @map("created_at")
  updatedAt                      DateTime          @updatedAt @map("updated_at")

  // Bulk swap / Jito bundle fields
  bundleId                       String?           @map("bundle_id") // Jito bundle ID (shared across bundle transactions)
  transactionIndex               Int               @default(0) @map("transaction_index") // Position in bundle (0, 1, 2...)
  bundleSlot                     BigInt?           @map("bundle_slot") // Slot where bundle landed

  // Relations
  offer        SwapOffer  @relation("OfferTransactions", fields: [offerId], references: [id], onDelete: Cascade)
  counterOffer SwapOffer? @relation("CounterOfferTransactions", fields: [counterOfferId], references: [id])
  maker        User       @relation("MakerTransactions", fields: [makerWallet], references: [walletAddress])
  taker        User       @relation("TakerTransactions", fields: [takerWallet], references: [walletAddress])

  @@index([offerId])
  @@index([counterOfferId])
  @@index([makerWallet])
  @@index([takerWallet])
  @@index([status])
  @@index([transactionSignature])
  @@index([confirmedAt])
  @@index([bundleId])
  @@map("swap_transactions")
}

// ============================================
// ZERO-FEE AUTHORIZATION SYSTEM
// ============================================

// Authorized apps table for zero-fee swap authorization
model AuthorizedApp {
  id               String   @id @default(uuid())
  name             String // App or partner name
  apiKey           String   @unique @map("api_key") // SHA256 hashed API key
  description      String? // Optional description
  active           Boolean  @default(true) // Can be disabled without deletion
  zeroFeeEnabled   Boolean  @default(true) @map("zero_fee_enabled") // Zero-fee authorization
  rateLimitPerDay  Int      @default(1000) @map("rate_limit_per_day") // Daily swap limit
  totalSwaps       Int      @default(0) @map("total_swaps") // Total swaps executed
  lastUsedAt       DateTime? @map("last_used_at") // Last time API key was used
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  zeroFeeSwapLogs ZeroFeeSwapLog[]

  @@index([apiKey])
  @@index([active])
  @@index([zeroFeeEnabled])
  @@index([lastUsedAt])
  @@map("authorized_apps")
}

// Zero-fee swap audit log
model ZeroFeeSwapLog {
  id                 String   @id @default(uuid())
  authorizedAppId    String   @map("authorized_app_id")
  swapSignature      String   @map("swap_signature") // Transaction signature
  makerWallet        String   @map("maker_wallet")
  takerWallet        String   @map("taker_wallet")
  platformFeeBps     Int      @map("platform_fee_bps") // Should be 0 for zero-fee
  totalValueLamports BigInt   @map("total_value_lamports")
  backendSigner      String   @map("backend_signer") // Which backend signer was used
  ipAddress          String?  @map("ip_address") // Request IP for security
  userAgent          String?  @map("user_agent") // Request user agent
  executedAt         DateTime @default(now()) @map("executed_at")

  // Relations
  authorizedApp AuthorizedApp @relation(fields: [authorizedAppId], references: [id], onDelete: Cascade)

  @@index([authorizedAppId])
  @@index([swapSignature])
  @@index([makerWallet])
  @@index([takerWallet])
  @@index([executedAt])
  @@map("zero_fee_swap_logs")
}

// ============================================
// CNFT OFFER ESCROW SYSTEM
// ============================================

// Enum for cNFT offer escrow status
enum OfferEscrowStatus {
  PENDING   // Offer created, awaiting SOL escrow confirmation
  ACTIVE    // SOL escrowed, awaiting seller response
  ACCEPTED  // Seller accepted the offer
  COUNTERED // Seller proposed different terms
  CANCELLED // Bidder cancelled the offer
  EXPIRED   // Offer expired based on expiresAt
  REJECTED  // Seller explicitly rejected the offer
}

// cNFT Offer table - offers on listed or unlisted cNFTs with SOL escrow
model CnftOffer {
  id              String             @id @default(uuid())
  offerId         String             @unique @map("offer_id") // External-facing ID

  // Bidder info
  bidderWallet    String             @map("bidder_wallet") // Offer creator wallet

  // Target cNFT details
  targetAssetId   String             @map("target_asset_id") // cNFT asset ID being bid on
  merkleTree      String?            @map("merkle_tree") // Cached merkle tree address
  leafIndex       Int?               @map("leaf_index") // Cached leaf index

  // cNFT owner (seller)
  ownerWallet     String             @map("owner_wallet") // Current owner of the cNFT

  // Offer amount (SOL only - no USDC)
  offerLamports   BigInt             @map("offer_lamports") // Offer amount in lamports

  // Platform fee
  feeLamports     BigInt             @map("fee_lamports") // Platform fee in lamports
  feeBps          Int                @default(100) @map("fee_bps") // Fee basis points (100 = 1%)

  // Escrow PDA
  escrowPda       String             @map("escrow_pda") // PDA holding bidder's SOL
  escrowBump      Int                @map("escrow_bump") // PDA bump seed

  // Status and timing
  status          OfferEscrowStatus  @default(PENDING)
  expiresAt       DateTime           @map("expires_at")

  // Transaction references
  escrowTxId      String?            @map("escrow_tx_id") // SOL escrow transaction
  acceptTxId      String?            @map("accept_tx_id") // Accept transaction (cNFT + SOL transfer)
  cancelTxId      String?            @map("cancel_tx_id") // Cancel/refund transaction
  rejectTxId      String?            @map("reject_tx_id") // Rejection transaction

  // Counter-offer chain
  counterOfferId  String?            @map("counter_offer_id") // Reference to counter offer
  parentOfferId   String?            @map("parent_offer_id") // If this is a counter, reference to original

  // Resolution timestamps
  acceptedAt      DateTime?          @map("accepted_at")
  cancelledAt     DateTime?          @map("cancelled_at")
  rejectedAt      DateTime?          @map("rejected_at")
  expiredAt       DateTime?          @map("expired_at")

  // Timestamps
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  // cNFT metadata cache (optional, for display)
  metadata        Json?              // Cached cNFT metadata (name, image, etc.)

  // Relations - self-referential for counter-offers
  counterOffer    CnftOffer?         @relation("CounterOffers", fields: [counterOfferId], references: [id])
  counterOffers   CnftOffer[]        @relation("CounterOffers")
  parentOffer     CnftOffer?         @relation("ParentOffers", fields: [parentOfferId], references: [id])
  childOffers     CnftOffer[]        @relation("ParentOffers")

  @@index([offerId])
  @@index([bidderWallet])
  @@index([ownerWallet])
  @@index([targetAssetId])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([status, expiresAt], name: "idx_offer_escrow_status_expiry")
  @@map("cnft_offers")
}

// ============================================
// TWO-PHASE SWAP STATE MACHINE (Task 8)
// ============================================

// Enum for two-phase swap status
// Supports bulk and cNFT swaps with lock → settle phases
enum TwoPhaseSwapStatus {
  CREATED         // Swap offer created, awaiting acceptance
  ACCEPTED        // Both parties agreed, ready to lock
  LOCKING_PARTY_A // Party A locking assets (delegation/escrow in progress)
  PARTY_A_LOCKED  // Party A assets delegated/escrowed
  LOCKING_PARTY_B // Party B locking assets
  FULLY_LOCKED    // Both parties locked, ready to settle
  SETTLING        // Transfers in progress
  PARTIAL_SETTLE  // Some transfers complete, continuing
  COMPLETED       // All transfers successful
  FAILED          // Unrecoverable error, needs intervention
  CANCELLED       // User cancelled before full lock
  EXPIRED         // Timeout during lock phase
}

// Two-phase swap state tracking for bulk and cNFT swaps
model TwoPhaseSwap {
  id              String              @id @default(uuid())

  // Status and timestamps
  status          TwoPhaseSwapStatus  @default(CREATED)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  expiresAt       DateTime            @map("expires_at") // Timeout for lock phase

  // Party information
  partyA          String              @map("party_a") // Initiator wallet address
  partyB          String?             @map("party_b") // Counterparty wallet address (null for open swaps)

  // Assets being swapped (stored as JSON arrays)
  assetsA         Json                @map("assets_a") // Party A's assets to transfer
  assetsB         Json                @map("assets_b") // Party B's assets to transfer

  // SOL amounts (in lamports)
  solAmountA      BigInt?             @map("sol_amount_a") // SOL from Party A
  solAmountB      BigInt?             @map("sol_amount_b") // SOL from Party B

  // Lock phase transaction signatures
  lockTxA         String?             @map("lock_tx_a") // Party A lock transaction signature
  lockTxB         String?             @map("lock_tx_b") // Party B lock transaction signature
  lockConfirmedA  DateTime?           @map("lock_confirmed_a") // When Party A lock was confirmed
  lockConfirmedB  DateTime?           @map("lock_confirmed_b") // When Party B lock was confirmed

  // Settlement phase tracking
  settleTxs       Json                @default("[]") @map("settle_txs") // Array of settlement tx signatures
  currentSettleIndex Int              @default(0) @map("current_settle_index") // Progress tracker for multi-tx settlement
  totalSettleTxs  Int                 @default(1) @map("total_settle_txs") // Total number of settlement transactions

  // Final settlement transaction (main atomic swap tx)
  finalSettleTx   String?             @map("final_settle_tx") // Final settlement signature
  settledAt       DateTime?           @map("settled_at") // When swap completed

  // Error tracking
  errorMessage    String?             @map("error_message") // Error details if FAILED
  errorCode       String?             @map("error_code") // Error code for categorization
  failedAt        DateTime?           @map("failed_at") // When swap failed

  // Cancellation tracking
  cancelledBy     String?             @map("cancelled_by") // Wallet that cancelled
  cancelledAt     DateTime?           @map("cancelled_at") // When cancelled
  cancelReason    String?             @map("cancel_reason") // Reason for cancellation

  // Platform fee
  platformFeeLamports BigInt          @map("platform_fee_lamports")

  // Reference to original swap offer (if created from offer)
  swapOfferId     Int?                @unique @map("swap_offer_id")
  swapOffer       SwapOffer?          @relation("TwoPhaseSwapOffer", fields: [swapOfferId], references: [id])

  // Delegation tracking for cNFTs
  delegationStatus Json               @default("{}") @map("delegation_status") // Per-asset delegation status

  // State transition history (audit trail)
  stateHistory    Json                @default("[]") @map("state_history") // Array of {state, timestamp, reason}

  @@index([status])
  @@index([partyA])
  @@index([partyB])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([status, expiresAt], name: "idx_two_phase_status_expiry")
  @@map("two_phase_swaps")
}

// ============================================
// INSTITUTION ESCROW SYSTEM
// Cross-border stablecoin (USDC) payments
