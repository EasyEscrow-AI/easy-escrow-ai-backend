// ============================================
// CLIENT & AUTH MODELS
// ============================================

// Institution client account (email + password auth)
model InstitutionClient {
  id              String        @id @default(uuid())
  email           String        @unique
  passwordHash    String        @map("password_hash")
  companyName     String        @map("company_name")
  tier            ClientTier    @default(STANDARD)
  status          ClientStatus  @default(PENDING_VERIFICATION)
  kycStatus       String        @default("PENDING") @map("kyc_status")
  jurisdiction    String?
  primaryWallet   String?       @map("primary_wallet")
  settledWallets  String[]      @default([]) @map("settled_wallets")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  lastLoginAt     DateTime?     @map("last_login_at")

  // Legal Entity
  legalName             String?          @map("legal_name")
  tradingName           String?          @map("trading_name")
  registrationNumber    String?          @map("registration_number")
  registrationCountry   String?          @map("registration_country")
  entityType            EntityType?      @map("entity_type")
  lei                   String?          // Legal Entity Identifier
  taxId                 String?          @map("tax_id")
  taxCountry            String?          @map("tax_country")

  // Registered Address
  addressLine1          String?          @map("address_line_1")
  addressLine2          String?          @map("address_line_2")
  city                  String?
  state                 String?
  postalCode            String?          @map("postal_code")
  country               String?

  // Primary Contact
  contactFirstName      String?          @map("contact_first_name")
  contactLastName       String?          @map("contact_last_name")
  contactEmail          String?          @map("contact_email")
  contactPhone          String?          @map("contact_phone")
  contactTitle          String?          @map("contact_title")

  // Compliance
  kybStatus             KybStatus?       @map("kyb_status")
  kybVerifiedAt         DateTime?        @map("kyb_verified_at")
  kybExpiresAt          DateTime?        @map("kyb_expires_at")
  riskRating            RiskRating?      @map("risk_rating")
  riskNotes             String?          @map("risk_notes")
  sanctionsStatus       SanctionsStatus? @map("sanctions_status")
  sourceOfFunds         String?          @map("source_of_funds")

  // Regulatory
  isRegulatedEntity     Boolean?         @map("is_regulated_entity")
  regulatoryStatus      RegulatoryStatus? @map("regulatory_status")
  licenseType           String?          @map("license_type")
  licenseNumber         String?          @map("license_number")
  regulatoryBody        String?          @map("regulatory_body")

  // Business
  industry              String?
  websiteUrl            String?          @map("website_url")
  businessDescription   String?          @map("business_description")
  yearEstablished       Int?             @map("year_established")
  employeeCountRange    EmployeeCountRange? @map("employee_count_range")
  annualRevenueRange    AnnualRevenueRange? @map("annual_revenue_range")
  expectedMonthlyVolume Decimal?         @map("expected_monthly_volume") @db.Decimal(20, 6)
  purposeOfAccount      String?          @map("purpose_of_account")

  // Crypto
  walletCustodyType     WalletCustodyType? @map("wallet_custody_type")
  custodianName         String?          @map("custodian_name")
  preferredSettlementChain String?       @map("preferred_settlement_chain")

  // Account Management
  accountManagerName    String?          @map("account_manager_name")
  accountManagerEmail   String?          @map("account_manager_email")
  onboardingCompletedAt DateTime?        @map("onboarding_completed_at")
  nextReviewDate        DateTime?        @map("next_review_date")
  referralSource        String?          @map("referral_source")
  isTestAccount         Boolean          @default(false) @map("is_test_account")
  isArchived            Boolean          @default(false) @map("is_archived")

  // Relations
  refreshTokens   InstitutionRefreshToken[]
  settings        InstitutionClientSettings?
  apiKeys         InstitutionApiKey[]
  escrows         InstitutionEscrow[]
  auditLogs       InstitutionAuditLog[]
  files           InstitutionFile[]
  wallets         InstitutionWallet[]
  accounts        InstitutionAccount[]
  aiAnalyses      InstitutionAiAnalysis[] @relation("ClientAiAnalyses")
  notifications   InstitutionNotification[]

  @@index([email])
  @@index([status])
  @@index([tier])
  @@index([primaryWallet])
  @@index([createdAt])
  @@index([isArchived])
  @@index([industry])
  @@index([country])
  @@index([kybStatus])
  @@map("institution_clients")
}

// Institution wallet management (replaces flat primaryWallet/settledWallets)
model InstitutionWallet {
  id            String    @id @default(uuid())
  clientId      String    @map("client_id")
  name          String
  address       String
  chain         String    @default("solana")
  description   String?
  provider      String?
  isPrimary     Boolean   @default(false) @map("is_primary")
  isSettlement  Boolean   @default(false) @map("is_settlement")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  client        InstitutionClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([address])
  @@index([isPrimary])
  @@index([isSettlement])
  @@map("institution_wallets")
}

// Institution multi-account system (Treasury, Operations, Settlement, etc.)
model InstitutionAccount {
  id          String   @id @default(uuid())
  clientId    String   @map("client_id")

  // Identity
  name        String
  label       String?
  accountType InstitutionAccountType       @default(GENERAL) @map("account_type")
  description String?

  // Wallet
  walletAddress  String  @map("wallet_address")
  chain          String  @default("solana")
  walletProvider String? @map("wallet_provider")
  custodyType    WalletCustodyType? @map("custody_type")

  // Verification (per-account, separate from client KYB)
  verificationStatus AccountVerificationStatus @default(PENDING) @map("verification_status")
  verifiedAt         DateTime?                 @map("verified_at")
  verificationNotes  String?                   @map("verification_notes")

  // Transaction limits (per-account overrides)
  maxTransactionAmount         Decimal? @map("max_transaction_amount") @db.Decimal(20, 6)
  minTransactionAmount         Decimal? @map("min_transaction_amount") @db.Decimal(20, 6)
  dailyVolumeLimit             Decimal? @map("daily_volume_limit") @db.Decimal(20, 6)
  monthlyVolumeLimit           Decimal? @map("monthly_volume_limit") @db.Decimal(20, 6)
  dailyTransactionCountLimit   Int?     @map("daily_transaction_count_limit")
  monthlyTransactionCountLimit Int?     @map("monthly_transaction_count_limit")

  // Approval settings
  approvalMode      ApprovalMode @default(AUTO) @map("approval_mode")
  approvalThreshold Decimal?     @map("approval_threshold") @db.Decimal(20, 6)

  // Security
  whitelistedAddresses String[] @default([]) @map("whitelisted_addresses")
  whitelistEnforced    Boolean  @default(false) @map("whitelist_enforced")

  // Notifications
  notificationEmail       String?  @map("notification_email")
  webhookUrl              String?  @map("webhook_url")
  notifyOnEscrowCreated   Boolean  @default(true) @map("notify_on_escrow_created")
  notifyOnEscrowFunded    Boolean  @default(true) @map("notify_on_escrow_funded")
  notifyOnEscrowReleased  Boolean  @default(true) @map("notify_on_escrow_released")
  notifyOnComplianceAlert Boolean  @default(true) @map("notify_on_compliance_alert")

  // Account preferences
  defaultCurrency String @default("USDC") @map("default_currency")

  // Status
  isDefault Boolean @default(false) @map("is_default")
  isActive  Boolean @default(true)  @map("is_active")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  client InstitutionClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, name])
  @@index([clientId])
  @@index([walletAddress])
  @@index([accountType])
  @@index([verificationStatus])
  @@index([isActive])
  @@map("institution_accounts")
}

// Institution branch (sub-entity of client for geographic presence)
model InstitutionBranch {
  id               String   @id @default(uuid())
  clientId         String   @map("client_id")
  name             String
  city             String
  country          String
  countryCode      String   @map("country_code") // ISO 3166-1 alpha-2
  address          String?
  timezone         String   @default("UTC")
  riskScore        Int      @default(0) @map("risk_score")
  complianceStatus String   @default("ACTIVE") @map("compliance_status") // ACTIVE, SUSPENDED, UNDER_REVIEW, BLOCKED
  complianceNote   String?  @map("compliance_note")
  regulatoryBody   String?  @map("regulatory_body")
  isSanctioned     Boolean  @default(false) @map("is_sanctioned")
  sanctionReason   String?  @map("sanction_reason")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  client   InstitutionClient   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  accounts InstitutionAccount[]

  @@index([clientId])
  @@index([countryCode])
  @@index([complianceStatus])
  @@map("institution_branches")
}

// Direct payments (non-escrow transfers between institutions)
model DirectPayment {
  id                String    @id @default(uuid())
  paymentCode       String?   @unique @map("payment_code") // Human-readable ID: EE-XXX-XXX
  clientId          String    @map("client_id")
  sender            String    // sender name/label
  senderCountry     String    @map("sender_country")
  senderWallet      String    @map("sender_wallet")
  recipient         String    // recipient name
  recipientCountry  String    @map("recipient_country")
  recipientWallet   String    @map("recipient_wallet")
  amount            Decimal   @db.Decimal(20, 6)
  currency          String    @default("USDC")
  corridor          String
  status            String    @default("processing") // completed, processing, failed
  txHash            String?   @map("tx_hash")
  platformFee       Decimal   @default(0) @map("platform_fee") @db.Decimal(20, 6)
  riskScore         Int?      @map("risk_score")
  settlementMode    String    @default("direct") @map("settlement_mode")
  releaseMode       String    @default("manual") @map("release_mode")
  settledAt         DateTime? @map("settled_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  client InstitutionClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([paymentCode])
  @@index([status])
  @@index([corridor])
  @@index([createdAt])
  @@map("direct_payments")
}

// Refresh token storage (hashed)
model InstitutionRefreshToken {
  id          String    @id @default(uuid())
  tokenHash   String    @unique @map("token_hash")
  clientId    String    @map("client_id")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  deviceInfo  String?   @map("device_info")
  ipAddress   String?   @map("ip_address")
  createdAt   DateTime  @default(now()) @map("created_at")

  client      InstitutionClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([expiresAt])
  @@index([tokenHash])
  @@map("institution_refresh_tokens")
}

// Per-client settings
model InstitutionClientSettings {
  id                        String    @id @default(uuid())
  clientId                  String    @unique @map("client_id")
  defaultCorridor           String?   @map("default_corridor")
  defaultCurrency           String    @default("USDC") @map("default_currency")
  notificationEmail         String?   @map("notification_email")
  webhookUrl                String?   @map("webhook_url")
  webhookSecret             String?   @map("webhook_secret")
  settlementAuthorityWallet String?   @map("settlement_authority_wallet")
  timezone                  String    @default("UTC")
  autoApproveThreshold      Decimal?  @map("auto_approve_threshold") @db.Decimal(20, 6)
  manualReviewThreshold     Decimal?  @map("manual_review_threshold") @db.Decimal(20, 6)
  autoTravelRule            Boolean   @default(true) @map("auto_travel_rule")
  activeSanctionsLists      String[]  @default(["OFAC SDN", "EU Consolidated", "UN Sanctions"]) @map("active_sanctions_lists")
  aiAutoRelease             Boolean   @default(false) @map("ai_auto_release")
  riskTolerance             String    @default("low") @map("risk_tolerance") // low, medium, high
  defaultToken              String    @default("usdc") @map("default_token")
  emailNotifications        Boolean   @default(true) @map("email_notifications")
  language                  String?   // en, de, fr, ar, zh, es
  theme                     String?   // light, dark, system
  twoFactorEnabled          Boolean   @default(false) @map("two_factor_enabled")
  aiRecommendations         Boolean   @default(true) @map("ai_recommendations")
  feeBps                    Int       @default(20) @map("fee_bps")  // Fee in basis points (default 0.20%)
  minFeeUsdc                Decimal   @default(0.20) @map("min_fee_usdc") @db.Decimal(20, 6)  // Minimum fee in USDC
  maxFeeUsdc                Decimal   @default(20.00) @map("max_fee_usdc") @db.Decimal(20, 6)  // Maximum fee in USDC
  notificationPreferences   Json?     @map("notification_preferences")  // Per-event notification prefs [{event, inApp, email, sms}]
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  client    InstitutionClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("institution_client_settings")
}

// API key management
model InstitutionApiKey {
  id          String    @id @default(uuid())
  clientId    String    @map("client_id")
  keyHash     String    @unique @map("key_hash")
  name        String
  permissions String[]  @default([])
  active      Boolean   @default(true)
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  client      InstitutionClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([keyHash])
  @@index([active])
  @@map("institution_api_keys")
}

// ============================================
// ESCROW MODELS
// ============================================

// Core institution escrow record
model InstitutionEscrow {
  id                    String                    @id @default(uuid())
  escrowId              String                    @unique @map("escrow_id") // UUID for on-chain PDA derivation
  escrowCode            String                    @unique @map("escrow_code") // Human-readable ID: EE-XXX-XXX
  clientId              String                    @map("client_id")
  payerWallet           String                    @map("payer_wallet")
  recipientWallet       String?                   @map("recipient_wallet")
  usdcMint              String                    @map("usdc_mint")
  amount                Decimal                   @db.Decimal(20, 6) // USDC amount (6 decimal precision)
  platformFee           Decimal                   @map("platform_fee") @db.Decimal(20, 6)
  corridor              String?                   // e.g. 'SG-CH'
  conditionType         InstitutionConditionType? @map("condition_type")
  status                InstitutionEscrowStatus   @default(CREATED)
  settlementAuthority   String                    @map("settlement_authority")
  riskScore             Int?                      @map("risk_score")

  // Settlement & release configuration
  settlementMode        String?                   @map("settlement_mode") // "escrow" | "direct"
  releaseMode           String?                   @map("release_mode") // "manual" | "ai"
  approvalParties       String[]                  @default([]) @map("approval_parties")
  releaseConditions     String[]                  @default([]) @map("release_conditions")
  approvalInstructions  String?                   @map("approval_instructions")

  // On-chain references
  escrowPda             String?                   @map("escrow_pda")
  vaultPda              String?                   @map("vault_pda")
  nonceAccount          String?                   @map("nonce_account")
  initTxSignature       String?                   @map("init_tx_signature")
  depositTxSignature    String?                   @map("deposit_tx_signature")
  releaseTxSignature    String?                   @map("release_tx_signature")
  cancelTxSignature     String?                   @map("cancel_tx_signature")

  // Timestamps
  expiresAt             DateTime?                 @map("expires_at")
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")
  resolvedAt            DateTime?                 @map("resolved_at")
  fundedAt              DateTime?                 @map("funded_at")

  // Relations
  client                InstitutionClient         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  deposits              InstitutionDeposit[]
  auditLogs             InstitutionAuditLog[]
  aiAnalyses            InstitutionAiAnalysis[]
  files                 InstitutionFile[]

  @@index([clientId])
  @@index([escrowId])
  @@index([escrowCode])
  @@index([status])
  @@index([corridor])
  @@index([payerWallet])
  @@index([recipientWallet])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([status, expiresAt], name: "idx_inst_escrow_status_expiry")
  @@index([clientId, status], name: "idx_inst_escrow_client_status")
  @@map("institution_escrows")
}

// Deposit tracking
model InstitutionDeposit {
  id              String    @id @default(uuid())
  escrowId        String    @map("escrow_id")
  txSignature     String    @map("tx_signature")
  amount          Decimal   @db.Decimal(20, 6)
  confirmedAt     DateTime? @map("confirmed_at")
  blockHeight     BigInt?   @map("block_height")
  createdAt       DateTime  @default(now()) @map("created_at")

  escrow          InstitutionEscrow @relation(fields: [escrowId], references: [escrowId], onDelete: Cascade)

  @@index([escrowId])
  @@index([txSignature])
  @@map("institution_deposits")
}

// Audit trail
model InstitutionAuditLog {
  id          String    @id @default(uuid())
  escrowId    String?   @map("escrow_id")
  clientId    String?   @map("client_id")
  action      String    // e.g. 'ESCROW_CREATED', 'DEPOSIT_CONFIRMED', 'FUNDS_RELEASED'
  actor       String    // wallet or system identifier
  details     Json      @default("{}")
  ipAddress   String?   @map("ip_address")
  createdAt   DateTime  @default(now()) @map("created_at")

  escrow      InstitutionEscrow?  @relation(fields: [escrowId], references: [escrowId], onDelete: SetNull)
  client      InstitutionClient?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([escrowId])
  @@index([clientId])
  @@index([action])
  @@index([createdAt])
  @@map("institution_audit_logs")
}

// AI analysis results (document, escrow-level, and client-level)
model InstitutionAiAnalysis {
  id              String          @id @default(uuid())
  analysisType    AiAnalysisType  @default(DOCUMENT) @map("analysis_type")
  escrowId        String?         @map("escrow_id")
  clientId        String?         @map("client_id")
  fileId          String?         @map("file_id")
  documentHash    String?         @map("document_hash")
  riskScore       Int             @map("risk_score") // 0-100
  factors         Json            @default("[]") // Array of {name, weight, value}
  recommendation  String          // APPROVE, REVIEW, REJECT
  extractedFields Json            @default("{}") @map("extracted_fields")
  summary         String?         // Human-readable analysis summary
  model           String          // AI model used
  createdAt       DateTime        @default(now()) @map("created_at")

  escrow          InstitutionEscrow?  @relation(fields: [escrowId], references: [escrowId], onDelete: Cascade)
  client          InstitutionClient?  @relation("ClientAiAnalyses", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([analysisType])
  @@index([escrowId])
  @@index([clientId])
  @@index([riskScore])
  @@index([recommendation])
  @@index([createdAt])
  @@map("institution_ai_analyses")
}

enum AiAnalysisType {
  DOCUMENT
  ESCROW
  CLIENT
}

// Corridor configuration
model InstitutionCorridor {
  id                String          @id @default(uuid())
  sourceCountry     String          @map("source_country")
  destCountry       String          @map("dest_country")
  code              String          @unique // e.g. 'SG-CH'
  minAmount         Decimal         @map("min_amount") @db.Decimal(20, 6)
  maxAmount         Decimal         @map("max_amount") @db.Decimal(20, 6)
  dailyLimit        Decimal         @map("daily_limit") @db.Decimal(20, 6)
  monthlyLimit      Decimal         @map("monthly_limit") @db.Decimal(20, 6)
  requiredDocuments String[]        @default([]) @map("required_documents")
  riskLevel         String          @default("MEDIUM") @map("risk_level") // LOW, MEDIUM, HIGH
  status            CorridorStatus  @default(ACTIVE)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@index([code])
  @@index([status])
  @@index([sourceCountry, destCountry], name: "idx_corridor_countries")
  @@map("institution_corridors")
}

// ============================================
// APPROVED TOKEN WHITELIST
// ============================================

// AMINA-approved stablecoin tokens for institution escrow
model InstitutionApprovedToken {
  id              String    @id @default(uuid())
  symbol          String    @unique // e.g. "USDC", "USDT", "EURC"
  name            String    // e.g. "USD Coin"
  mintAddress     String    @unique @map("mint_address") // Solana SPL token mint
  decimals        Int       @default(6)
  issuer          String    // e.g. "Circle", "Tether", "Ripple"
  jurisdiction    String?   // e.g. "US", "EU", "SG"
  chain           String    @default("solana")
  isDefault       Boolean   @default(false) @map("is_default") // USDC = default
  isActive        Boolean   @default(true) @map("is_active")
  aminaApproved   Boolean   @default(true) @map("amina_approved")
  addedAt         DateTime  @default(now()) @map("added_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([symbol])
  @@index([mintAddress])
  @@index([isActive])
  @@index([aminaApproved])
  @@map("institution_approved_tokens")
}

// ============================================
// ADMIN USER SYSTEM
// ============================================

enum AdminRole {
  SUPER_ADMIN
}

// Admin user account (seed-only, no public registration)
model AdminUser {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String
  role          AdminRole @default(SUPER_ADMIN)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")

  refreshTokens AdminRefreshToken[]

  @@index([email])
  @@index([isActive])
  @@map("admin_users")
}

// Admin refresh token storage (hashed)
model AdminRefreshToken {
  id          String    @id @default(uuid())
  tokenHash   String    @unique @map("token_hash")
  adminId     String    @map("admin_id")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  admin       AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
  @@index([tokenHash])
  @@map("admin_refresh_tokens")
}

// ============================================
// FILE MODEL
// ============================================

// File uploads to DO Spaces
model InstitutionFile {
  id            String        @id @default(uuid())
  clientId      String        @map("client_id")
  escrowId      String?       @map("escrow_id")
  fileName      String        @map("file_name")
  fileKey       String        @map("file_key") // DO Spaces object key
  mimeType      String        @map("mime_type")
  sizeBytes     Int           @map("size_bytes")
  documentType  DocumentType  @map("document_type")
  uploadedAt    DateTime      @default(now()) @map("uploaded_at")

  client        InstitutionClient   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  escrow        InstitutionEscrow?  @relation(fields: [escrowId], references: [escrowId], onDelete: SetNull)

  @@index([clientId])
  @@index([escrowId])
  @@index([documentType])
  @@index([uploadedAt])
  @@map("institution_files")
}

// ============================================
// NOTIFICATION MODEL
// ============================================

enum NotificationType {
  ESCROW_CREATED
  ESCROW_FUNDED
  ESCROW_RELEASED
  ESCROW_CANCELLED
  ESCROW_EXPIRED
  ESCROW_COMPLIANCE_HOLD
  KYC_APPROVED
  KYC_REJECTED
  KYC_EXPIRING
  KYB_VERIFIED
  KYB_REJECTED
  KYB_EXPIRING
  WALLET_WHITELISTED
  WALLET_REMOVED
  WALLET_VERIFICATION_PENDING
  COMPLIANCE_CHECK_PASSED
  COMPLIANCE_CHECK_FAILED
  COMPLIANCE_REVIEW_REQUIRED
  ACCOUNT_VERIFIED
  ACCOUNT_SUSPENDED
  DEPOSIT_CONFIRMED
  SETTLEMENT_COMPLETE
  SYSTEM_MAINTENANCE
  SECURITY_ALERT
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Institution notifications (in-app notification center)
model InstitutionNotification {
  id          String                @id @default(uuid())
  clientId    String                @map("client_id")
  escrowId    String?               @map("escrow_id")
  type        NotificationType
  priority    NotificationPriority  @default(MEDIUM)
  title       String
  message     String
  metadata    Json                  @default("{}")
  isRead      Boolean               @default(false) @map("is_read")
  readAt      DateTime?             @map("read_at")
  createdAt   DateTime              @default(now()) @map("created_at")

  client      InstitutionClient     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, isRead])
  @@index([type])
  @@index([createdAt])
  @@map("institution_notifications")
}

// ============================================
// SYSTEM SETTINGS
// ============================================

// Key-value store for runtime system settings (e.g., pause state)
model SystemSetting {
  key       String   @id
  value     Json     @default("{}")
  updatedBy String?  @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("system_settings")
}

