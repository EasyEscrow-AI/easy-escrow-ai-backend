// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum for agreement status
enum AgreementStatus {
  PENDING
  FUNDED
  USDC_LOCKED
  NFT_LOCKED
  BOTH_LOCKED
  SETTLED
  EXPIRED
  CANCELLED
  REFUNDED
}

// Enum for deposit type
enum DepositType {
  USDC
  NFT
}

// Enum for deposit status
enum DepositStatus {
  PENDING
  CONFIRMED
  FAILED
}

// Enum for webhook event type
enum WebhookEventType {
  ESCROW_FUNDED
  ESCROW_ASSET_LOCKED
  ESCROW_SETTLED
  ESCROW_EXPIRED
  ESCROW_REFUNDED
}

// Enum for webhook delivery status
enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

// Main Agreements table
model Agreement {
  id               String           @id @default(uuid())
  agreementId      String           @unique @map("agreement_id")
  escrowPda        String           @map("escrow_pda")
  nftMint          String           @map("nft_mint")
  seller           String
  buyer            String?
  price            Decimal          @db.Decimal(20, 9)
  feeBps           Int              @map("fee_bps")
  honorRoyalties   Boolean          @default(false) @map("honor_royalties")
  status           AgreementStatus  @default(PENDING)
  expiry           DateTime
  usdcDepositAddr  String?          @map("usdc_deposit_addr")
  nftDepositAddr   String?          @map("nft_deposit_addr")
  initTxId         String?          @map("init_tx_id")
  settleTxId       String?          @map("settle_tx_id")
  cancelTxId       String?          @map("cancel_tx_id")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  settledAt        DateTime?        @map("settled_at")
  cancelledAt      DateTime?        @map("cancelled_at")
  
  deposits         Deposit[]
  settlement       Settlement?
  receipt          Receipt?
  webhooks         Webhook[]
  
  @@index([agreementId])
  @@index([seller])
  @@index([buyer])
  @@index([status])
  @@index([expiry])
  @@index([createdAt])
  @@map("agreements")
}

// Deposits table
model Deposit {
  id            String         @id @default(uuid())
  agreementId   String         @map("agreement_id")
  type          DepositType
  depositor     String
  amount        Decimal?       @db.Decimal(20, 9)
  tokenAccount  String?        @map("token_account")
  status        DepositStatus  @default(PENDING)
  txId          String?        @map("tx_id")
  blockHeight   BigInt?        @map("block_height")
  nftMetadata   Json?          @map("nft_metadata")
  detectedAt    DateTime       @default(now()) @map("detected_at")
  confirmedAt   DateTime?      @map("confirmed_at")
  
  agreement     Agreement      @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  
  @@index([agreementId])
  @@index([type])
  @@index([status])
  @@index([depositor])
  @@index([detectedAt])
  @@map("deposits")
}

// Idempotency keys table - prevents duplicate operations
model IdempotencyKey {
  id             String   @id @default(uuid())
  key            String   @unique
  endpoint       String
  requestHash    String   @map("request_hash")
  responseStatus Int      @map("response_status")
  responseBody   Json     @map("response_body")
  createdAt      DateTime @default(now()) @map("created_at")
  expiresAt      DateTime @map("expires_at")

  @@index([key])
  @@index([endpoint])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// Settlements table
model Settlement {
  id                String     @id @default(uuid())
  agreementId       String     @unique @map("agreement_id")
  nftMint           String     @map("nft_mint")
  price             Decimal    @db.Decimal(20, 9)
  platformFee       Decimal    @db.Decimal(20, 9) @map("platform_fee")
  creatorRoyalty    Decimal?   @db.Decimal(20, 9) @map("creator_royalty")
  sellerReceived    Decimal    @db.Decimal(20, 9) @map("seller_received")
  settleTxId        String     @map("settle_tx_id")
  blockHeight       BigInt     @map("block_height")
  buyer             String
  seller            String
  feeCollector      String?    @map("fee_collector")
  royaltyRecipient  String?    @map("royalty_recipient")
  settledAt         DateTime   @default(now()) @map("settled_at")
  
  agreement         Agreement  @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  
  @@index([agreementId])
  @@index([buyer])
  @@index([seller])
  @@index([nftMint])
  @@index([settledAt])
  @@map("settlements")
}

// Receipts table
model Receipt {
  id              String     @id @default(uuid())
  agreementId     String     @unique @map("agreement_id")
  nftMint         String     @map("nft_mint")
  price           Decimal    @db.Decimal(20, 9)
  platformFee     Decimal    @db.Decimal(20, 9) @map("platform_fee")
  creatorRoyalty  Decimal?   @db.Decimal(20, 9) @map("creator_royalty")
  buyer           String
  seller          String
  escrowTxId      String     @map("escrow_tx_id")
  settlementTxId  String     @map("settlement_tx_id")
  receiptHash     String     @unique @map("receipt_hash")
  signature       String
  createdAt       DateTime   @map("created_at")
  settledAt       DateTime   @map("settled_at")
  generatedAt     DateTime   @default(now()) @map("generated_at")
  
  agreement       Agreement  @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  
  @@index([agreementId])
  @@index([buyer])
  @@index([seller])
  @@index([nftMint])
  @@index([receiptHash])
  @@index([generatedAt])
  @@map("receipts")
}

// Transaction logs table
model TransactionLog {
  id            String    @id @default(uuid())
  agreementId   String?   @map("agreement_id")
  txId          String    @unique @map("tx_id")
  operationType String    @map("operation_type")
  blockHeight   BigInt?   @map("block_height")
  slot          BigInt?
  status        String
  errorMessage  String?   @map("error_message")
  timestamp     DateTime  @default(now())
  
  @@index([agreementId])
  @@index([txId])
  @@index([operationType])
  @@index([status])
  @@index([timestamp])
  @@map("transaction_logs")
}

// Webhooks table
model Webhook {
  id                String                @id @default(uuid())
  agreementId       String                @map("agreement_id")
  eventType         WebhookEventType      @map("event_type")
  targetUrl         String                @map("target_url")
  payload           Json
  status            WebhookDeliveryStatus @default(PENDING)
  attempts          Int                   @default(0)
  maxAttempts       Int                   @default(5) @map("max_attempts")
  lastAttemptAt     DateTime?             @map("last_attempt_at")
  lastResponseCode  Int?                  @map("last_response_code")
  lastResponseBody  String?               @map("last_response_body")
  deliveredAt       DateTime?             @map("delivered_at")
  signature         String?
  createdAt         DateTime              @default(now()) @map("created_at")
  scheduledFor      DateTime              @default(now()) @map("scheduled_for")
  
  agreement         Agreement             @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  
  @@index([agreementId])
  @@index([eventType])
  @@index([status])
  @@index([scheduledFor])
  @@index([createdAt])
  @@map("webhooks")
}
