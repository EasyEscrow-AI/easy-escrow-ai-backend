# Git Secrets Patterns
# Patterns to detect potential secrets in commits

# Private keys and keypairs (Base58 Solana format - typically 88 characters)
[0-9A-HJ-NP-Za-km-z]{87,88}

# JSON array format keypairs (Solana keypair files)
\[[0-9,\s]{100,}\]

# API Keys and Tokens
(api[_-]?key|apikey)["\s:=]+[A-Za-z0-9_\-]{20,}
(secret[_-]?key|secretkey)["\s:=]+[A-Za-z0-9_\-]{20,}
(access[_-]?token|accesstoken)["\s:=]+[A-Za-z0-9_\-]{20,}
(auth[_-]?token|authtoken)["\s:=]+[A-Za-z0-9_\-]{20,}

# AWS Keys
AKIA[0-9A-Z]{16}
aws_access_key_id["\s:=]+[A-Z0-9]{20}
aws_secret_access_key["\s:=]+[A-Za-z0-9/+=]{40}

# Generic secrets
(password|passwd|pwd)["\s:=]+[^\s]{8,}
(secret|token|key)["\s:=]+["\'][A-Za-z0-9_\-]{20,}["\']

# Private key files content
-----BEGIN\s+(RSA\s+)?PRIVATE\sKEY-----
-----BEGIN\sOPENSSH\sPRIVATE\sKEY-----
-----BEGIN\sPGP\sPRIVATE\sKEY\sBLOCK-----

# Database connection strings
(mongodb|mysql|postgresql|postgres|mssql):\/\/[^\s]+:[^\s]+@

# JWT tokens (Bearer tokens)
eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}

# Environment variable assignments with secrets
export\s+(SECRET|PASSWORD|TOKEN|KEY|PRIVATE)[A-Z_]*=[^\s]+

# Hex-encoded keys (32+ bytes)
[0-9a-fA-F]{64,}

# Base64 encoded data that might be secrets (100+ characters)
[A-Za-z0-9+/]{100,}={0,2}

